/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background: #0f0f1e;
  color: #e0e0e0;
  padding: 24rpx 32rpx 80rpx;
  font-family: -apple-system, "PingFang SC", sans-serif;
}

.section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffd700;
  margin-bottom: 12rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-active {
  background: rgba(255, 215, 0, 0.12);
  border-color: #ffd700;
}

.option-label {
  font-size: 28rpx;
}

.option-check {
  color: #ffd700;
  font-size: 32rpx;
  font-weight: 700;
}

.info-line {
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.action-bar {
  padding: 32rpx 0;
}

.btn-save {
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
}

.footer {
  text-align: center;
  color: #555;
  font-size: 22rpx;
  line-height: 1.6;
  padding: 32rpx 0;
}
