/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background: #0f0f1e;
  color: #e0e0e0;
  padding: 24rpx 32rpx 80rpx;
  font-family: -apple-system, "PingFang SC", sans-serif;
}

.section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffd700;
  margin-bottom: 12rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-active {
  background: rgba(255, 215, 0, 0.12);
  border-color: #ffd700;
}

.option-label {
  font-size: 28rpx;
}

.option-check {
  color: #ffd700;
  font-size: 32rpx;
  font-weight: 700;
}

.info-line {
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

/* ===== 异动推送 ===== */
.notify-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.notify-label-wrap {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-right: 24rpx;
}

.notify-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0e0;
}

.notify-hint {
  font-size: 22rpx;
  color: #777;
  margin-top: 6rpx;
  line-height: 1.4;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ccc;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.threshold-options {
  margin-bottom: 24rpx;
}

/* 订阅状态卡片 */
.subscribe-status {
  margin-top: 8rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.subscribe-status.status-ok {
  background: rgba(0, 200, 120, 0.08);
  border-color: rgba(0, 200, 120, 0.4);
}

.subscribe-status.status-empty {
  background: rgba(255, 140, 0, 0.08);
  border-color: rgba(255, 140, 0, 0.4);
}

.status-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.status-label {
  font-size: 26rpx;
  color: #bbb;
}

.status-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffd700;
}

.status-tip {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.btn-resub {
  background: rgba(255, 215, 0, 0.15);
  color: #ffd700;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
  height: 76rpx;
  line-height: 76rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.5);
}

.btn-resub::after {
  border: none;
}

/* ===== 操作栏 ===== */
.action-bar {
  padding: 32rpx 0;
}

.btn-save {
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
}

.footer {
  text-align: center;
  color: #555;
  font-size: 22rpx;
  line-height: 1.6;
  padding: 32rpx 0;
}
