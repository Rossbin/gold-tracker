/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f1e 0%, #1a1a2e 100%);
  color: #e0e0e0;
  padding-bottom: 140rpx;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffd700;
  letter-spacing: 2rpx;
  text-shadow: 0 0 16rpx rgba(255, 215, 0, 0.3);
}

.header-subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  font-size: 26rpx;
}

.toolbar-info {
  color: #888;
}

.toolbar-btn {
  color: #ffd700;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ffd700;
  border-radius: 8rpx;
}

/* 分区标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ccc;
  padding: 24rpx 32rpx 12rpx;
  letter-spacing: 1rpx;
}

/* ========== 银行卡片（新版详细卡片） ========== */
.card-list {
  padding: 0 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #ffd700;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
  transition: all 0.3s ease;
}

.card-flash {
  animation: flash 1.2s ease;
}

@keyframes flash {
  0%   { background: rgba(255, 215, 0, 0.18); transform: scale(1.02); }
  50%  { background: rgba(255, 215, 0, 0.32); }
  100% { background: rgba(255, 255, 255, 0.06); transform: scale(1); }
}

/* 卡片头部：银行名 + 品种 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bank-name {
  font-size: 34rpx;
  font-weight: 700;
}

.product-tag {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #aaa;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

/* 主价格区域 */
.card-main-price {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.main-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.main-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #ffd700;
  font-family: "DIN Alternate", "SF Pro Display", monospace;
  line-height: 1.1;
  letter-spacing: -2rpx;
}

.main-unit {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 涨跌信息行 */
.card-change-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.change-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.change-badge.up {
  background: rgba(255, 82, 82, 0.12);
  color: #ff5252;
}

.change-badge.down {
  background: rgba(76, 175, 80, 0.12);
  color: #4caf50;
}

.change-badge.flat {
  background: rgba(136, 136, 136, 0.12);
  color: #888;
}

.change-arrow {
  font-size: 24rpx;
}

.change-amount {
  font-size: 26rpx;
  font-weight: 500;
}

.change-amount.up { color: #ff5252; }
.change-amount.down { color: #4caf50; }
.change-amount.flat { color: #888; }

/* 分割线 */
.card-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 16rpx 0;
}

/* 详细数据：最高/最低/买入 */
.card-details {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.detail-item {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.detail-icon {
  font-size: 28rpx;
  margin-top: 4rpx;
  color: #ffd700;
}

.detail-icon.down-icon {
  color: #4caf50;
}

.detail-content {
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 22rpx;
  color: #777;
  margin-bottom: 4rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e0e0;
  font-family: "DIN Alternate", monospace;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 8rpx;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.footer-icon {
  font-size: 22rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #666;
}

.footer-time {
  font-size: 22rpx;
  color: #555;
  background: rgba(255, 255, 255, 0.04);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.footer-right {
  font-size: 20rpx;
  color: #444;
}

.source-text {
  font-size: 20rpx;
  color: #444;
}

/* ========== 国际金价 ========== */
.intl-card {
  border-left-color: #42a5f5;
  margin: 0 24rpx;
}

.intl-color {
  color: #42a5f5 !important;
}

.intl-price {
  color: #42a5f5 !important;
}

/* ========== 首饰金价 ========== */
.jewelry-section {
  padding: 0 24rpx;
}

.jewelry-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.jewelry-item {
  flex: 0 0 calc(33.333% - 12rpx);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.jewelry-brand {
  font-size: 26rpx;
  font-weight: 700;
  color: #e0e0e0;
  margin-bottom: 8rpx;
}

.jewelry-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffd700;
  font-family: "DIN Alternate", monospace;
}

.jewelry-unit {
  font-size: 20rpx;
  color: #888;
  font-weight: 400;
}

.jewelry-product {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.jewelry-note {
  font-size: 20rpx;
  color: #555;
  text-align: center;
  margin-top: 16rpx;
  padding-bottom: 8rpx;
}

/* ========== 空提示 ========== */
.empty-hint {
  text-align: center;
  color: #555;
  font-size: 24rpx;
  padding: 32rpx;
}

/* ========== 底部 ========== */
.footer {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  color: #555;
  font-size: 22rpx;
  line-height: 1.6;
}

.footer-tip {
  color: #555;
}

/* ========== 悬浮按钮 ========== */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
  color: #1a1a2e;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.4);
  z-index: 99;
}

.fab-icon {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.fab-label {
  font-size: 20rpx;
  font-weight: 600;
  margin-top: 4rpx;
}
