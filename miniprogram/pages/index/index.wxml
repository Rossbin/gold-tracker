<!-- pages/index/index.wxml -->
<view class="page">
  <view class="header">
    <view class="header-title">六大行积存金</view>
    <view class="header-subtitle">实时金价 · {{ lastUpdateTime ? fmt_time(lastUpdateTime) : '--' }} 更新</view>
  </view>

  <view class="toolbar">
    <view class="toolbar-info">
      <text wx:if="{{autoRefreshing}}">🔄 自动刷新中</text>
      <text wx:else>⏸ 自动刷新已暂停</text>
    </view>
    <view class="toolbar-btn" bindtap="goSettings">设置</view>
  </view>

  <view class="card-list">
    <view
      wx:for="{{list}}"
      wx:key="bank"
      class="card {{item.changed ? 'card-flash' : ''}}"
      style="border-left-color: {{bankColors[item.bank]}}"
    >
      <view class="card-row1">
        <view class="bank-name" style="color: {{bankColors[item.bank]}}">{{item.bankName}}</view>
        <view class="product-tag">{{item.product}}</view>
      </view>
      <view class="card-row2">
        <view class="price-block">
          <view class="price-label">银行卖出（元/克）</view>
          <view class="price-value">{{item.sellPriceText}}</view>
        </view>
        <view class="price-block">
          <view class="price-label">银行买入（元/克）</view>
          <view class="price-value-secondary">{{item.buyPriceText}}</view>
        </view>
      </view>
      <view class="card-row3">
        <view class="change {{item.change > 0 ? 'up' : item.change < 0 ? 'down' : 'flat'}}">
          {{item.changeText}} ({{item.changePctText}})
        </view>
        <view class="source">来源: {{item.source}}</view>
      </view>
      <view class="card-row4">
        <text class="time-text">报价: {{item.quoteTimeText}}</text>
        <text class="time-text">抓取: {{item.fetchTimeText}}</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-tip">数据来自公开行情源，仅供参考，不构成投资建议</view>
    <view class="footer-tip">实际成交以各银行柜台为准</view>
  </view>

  <view class="fab" bindtap="onTapRefreshNow">
    <text class="fab-icon">⟳</text>
    <text class="fab-label">立即刷新</text>
  </view>
</view>

<wxs module="fmt">
var pad2 = function(n) { return n < 10 ? '0' + n : '' + n; };
var formatTime = function(ts) {
  if (!ts) return '--';
  var d = getDate(ts);
  return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate()) + ' ' + pad2(d.getHours()) + ':' + pad2(d.getMinutes()) + ':' + pad2(d.getSeconds());
};
module.exports = { formatTime: formatTime };
</wxs>
