<!-- pages/index/index.wxml -->
<view class="page">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-title">积存金金价</view>
    <view class="header-subtitle">实时行情 · {{ lastUpdateTime ? fmt_time(lastUpdateTime) : '--' }} 更新</view>
  </view>

  <!-- 工具栏 -->
  <view class="toolbar">
    <view class="toolbar-info">
      <text wx:if="{{autoRefreshing}}">🔄 自动刷新中</text>
      <text wx:else>⏸ 自动刷新已暂停</text>
    </view>
    <view class="toolbar-btn" bindtap="goSettings">设置</view>
  </view>

  <!-- ========== 银行积存金卡片 ========== -->
  <view class="section-title">🏦 六大行积存金</view>
  <view class="card-list">
    <view
      wx:for="{{list}}"
      wx:key="bank"
      class="card {{item.changed ? 'card-flash' : ''}}"
      style="border-left-color: {{bankColors[item.bank]}}"
    >
      <!-- 银行名称 + 品种 -->
      <view class="card-header">
        <view class="bank-name" style="color: {{bankColors[item.bank]}}">{{item.bankName}}</view>
        <view class="product-tag">{{item.product}}</view>
      </view>

      <!-- 实时价格（大数字） -->
      <view class="card-main-price">
        <view class="main-label">实时积存金价格</view>
        <view class="main-value">{{item.sellPriceText}}</view>
        <view class="main-unit">元/克</view>
      </view>

      <!-- 涨跌信息行 -->
      <view class="card-change-row">
        <view class="change-badge {{item.isUp ? 'up' : item.isDown ? 'down' : 'flat'}}">
          <text class="change-arrow">{{item.isUp ? '▲' : item.isDown ? '▼' : '—'}}</text>
          <text>{{item.changePctText}}</text>
        </view>
        <view class="change-amount {{item.isUp ? 'up' : item.isDown ? 'down' : 'flat'}}">
          涨跌额: {{item.changeText}} 元
        </view>
      </view>

      <!-- 分割线 -->
      <view class="card-divider"></view>

      <!-- 详细数据：最高/最低/买入 -->
      <view class="card-details">
        <view class="detail-item">
          <view class="detail-icon">↑</view>
          <view class="detail-content">
            <view class="detail-label">今日最高价</view>
            <view class="detail-value">{{item.highPriceText || '--'}}</view>
          </view>
        </view>
        <view class="detail-item">
          <view class="detail-icon down-icon">↓</view>
          <view class="detail-content">
            <view class="detail-label">今日最低价</view>
            <view class="detail-value">{{item.lowPriceText || '--'}}</view>
          </view>
        </view>
        <view class="detail-item">
          <view class="detail-icon">💰</view>
          <view class="detail-content">
            <view class="detail-label">银行买入</view>
            <view class="detail-value">{{item.buyPriceText || '--'}}</view>
          </view>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="card-divider"></view>

      <!-- 底部信息 -->
      <view class="card-footer">
        <view class="footer-left">
          <text class="footer-icon">📊</text>
          <text class="footer-text">最新采集</text>
          <text class="footer-time">{{item.quoteTimeText}}</text>
        </view>
        <view class="footer-right">
          <text class="source-text">{{item.source}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 国际金价 ========== -->
  <view class="section-title">🌍 国际金价</view>
  <view class="card intl-card" wx:if="{{international}}">
    <view class="card-header">
      <view class="bank-name intl-color">国际现货黄金</view>
      <view class="product-tag">XAU/USD</view>
    </view>
    <view class="card-main-price">
      <view class="main-label">折合人民币（元/克）</view>
      <view class="main-value intl-price">{{international.sellPriceText}}</view>
    </view>
    <view class="card-change-row">
      <view class="change-badge {{international.change > 0 ? 'up' : international.change < 0 ? 'down' : 'flat'}}">
        <text>{{international.changeText}} ({{international.changePctText}})</text>
      </view>
    </view>
    <view class="card-footer" wx:if="{{international.rawPriceUSD}}">
      <view class="footer-left">
        <text class="footer-text">美元价: ${{international.rawPriceUSD}}/oz</text>
      </view>
      <view class="footer-right">
        <text class="footer-text">汇率: {{international.fxRate}}</text>
      </view>
    </view>
  </view>
  <view class="empty-hint" wx:else>
    <text>暂无国际金价数据，点"立即刷新"获取</text>
  </view>

  <!-- ========== 首饰金价 ========== -->
  <view class="section-title">💍 品牌首饰金价</view>
  <view class="jewelry-section" wx:if="{{jewelryBrands.length > 0}}">
    <view class="jewelry-grid">
      <view class="jewelry-item" wx:for="{{jewelryBrands}}" wx:key="brand">
        <view class="jewelry-brand">{{item.brand}}</view>
        <view class="jewelry-price">¥{{item.price}}<text class="jewelry-unit">/克</text></view>
        <view class="jewelry-product">{{item.product}}</view>
      </view>
    </view>
    <view class="jewelry-note">数据来自今日金价网，可能滞后1-3天，工费另计</view>
  </view>
  <view class="empty-hint" wx:else>
    <text>暂无首饰金价数据，点"立即刷新"获取</text>
  </view>

  <!-- 底部声明 -->
  <view class="footer">
    <view class="footer-tip">数据来自公开行情源，仅供参考，不构成投资建议</view>
    <view class="footer-tip">实际成交以各银行柜台为准</view>
  </view>

  <!-- 悬浮刷新按钮 -->
  <view class="fab" bindtap="onTapRefreshNow">
    <text class="fab-icon">⟳</text>
    <text class="fab-label">立即刷新</text>
  </view>
</view>

<wxs module="fmt">
var pad2 = function(n) { return n < 10 ? '0' + n : '' + n; };
var formatTime = function(ts) {
  if (!ts) return '--';
  var d = getDate(ts);
  return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate()) + ' ' + pad2(d.getHours()) + ':' + pad2(d.getMinutes()) + ':' + pad2(d.getSeconds());
};
module.exports = { formatTime: formatTime };
</wxs>
